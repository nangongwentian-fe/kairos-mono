{
  "name": "kairos-mono",
  "private": true,
  "packageManager": "bun",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "bun run --workspaces build",
    "typecheck": "bun run --workspaces typecheck",
    "coding-web:dev": "bun run --cwd apps/coding-web dev",
    "docs:dev": "bun run --cwd apps/docs-site dev",
    "docs:build": "bun run --cwd apps/docs-site build",
    "docs:preview": "bun run --cwd apps/docs-site preview",
    "test:agent": "bun test packages/agent/test",
    "test:agent:integration": "bun --env-file=.env.local test packages/agent/test/agent.integration.test.ts",
    "test:coding-agent": "bun test packages/coding-agent/test/read-file.test.ts packages/coding-agent/test/list-dir.test.ts packages/coding-agent/test/grep.test.ts packages/coding-agent/test/edit-file.test.ts packages/coding-agent/test/run-command.test.ts packages/coding-agent/test/todo-write.test.ts packages/coding-agent/test/tool-policy.test.ts packages/coding-agent/test/workspace-diff.test.ts packages/coding-agent/test/run-record.test.ts packages/coding-agent/test/coding-agent.test.ts packages/coding-agent/test/session.test.ts packages/coding-agent/test/session-store.test.ts packages/coding-agent/test/coding-task.test.ts packages/coding-agent/test/coding-agent-workflow.test.ts",
    "test:coding-agent:integration": "bun --env-file=.env.local test packages/coding-agent/test/read-file.integration.test.ts",
    "test:coding-agent:workflow:integration": "bun --env-file=.env.local test packages/coding-agent/test/coding-agent-workflow.integration.test.ts",
    "test:coding-tui": "bun test apps/coding-tui/test/cli.test.ts apps/coding-tui/test/interactive.test.ts apps/coding-tui/test/coding-tui-task.test.ts",
    "test:coding-tui:integration": "bun --env-file=.env.local test apps/coding-tui/test/coding-tui-json.integration.test.ts",
    "test:coding-web": "bun test apps/coding-web/test",
    "test:tui": "bun test packages/tui/test",
    "test:web-ui": "bun test packages/web-ui/test",
    "test:deps": "bun test test/package-boundaries.test.ts",
    "kairos": "bun --env-file=.env.local apps/coding-tui/src/cli.ts",
    "clean": "bun run --workspaces clean"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "typescript": "^6.0.3"
  }
}
